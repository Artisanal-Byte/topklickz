---
import "../styles/global.css";

export interface Props {
	title?: string;
	description?: string;
	keywords?: string;
}

const {
	title = "Topklickz",
	description = "Topklickz - Astro",
	keywords = "",
} = Astro.props;
---

<!doctype html>
<html lang="en" class="scroll-smooth bg-white">
	<head>
		<meta charset="UTF-8" />
		<meta name="description" content={description} />
		<meta name="keywords" content={keywords} />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>

		<!-- schema -->
	</head>
	<body
		class="min-h-screen overflow-x-hidden bg-[radial-gradient(circle_at_top_left,rgba(255,132,0,0.08),transparent_30%),radial-gradient(circle_at_85%_18%,rgba(124,58,237,0.08),transparent_28%),#ffffff] text-[#0f0f11] antialiased"
	>
		<slot />
	</body>
</html>
