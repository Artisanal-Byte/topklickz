---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import Hero from "../components/Hero.astro";

import { createReader } from "@keystatic/core/reader";
import config from "../../keystatic.config";
import Studio from "../components/Studio.astro";
import Services from "../components/Services.astro";
import Work from "../components/Work.astro";
import TrustedBrands from "../components/trustedBrands.astro";
import Testimonials from "../components/Testimonials.astro";
import FieldNotes from "../components/FieldNotes.astro";
import TeamCulture from "../components/TeamCulture.astro";
import Faq from "../components/Faq.astro";
import Cta from "../components/Cta.astro";
import Footer from "../components/Footer.astro";

const reader = createReader(process.cwd(), config);
const site = await reader.singletons.site.read();
---

<Layout
  title={site?.seo?.title}
  description={site?.seo?.description}
  keywords={site?.seo?.keywords}
>
  <Header navbar={site?.navbar} />
  <Hero hero={site?.hero} />
  <Studio studio={site?.studio} />
  <Services services={site?.services} />
  <Work work={site?.work} />
  <TrustedBrands trustedBrands={site?.trustedBrands} />
  <Testimonials testimonials={site?.testimonials} />
  <FieldNotes fieldNotes={site?.fieldNotes} />
  <TeamCulture teamCulture={site?.teamCulture} />
  <Faq faq={site?.faq} />
  <Cta cta={site?.cta} />
  <Footer footer={site?.footer} />
</Layout>
