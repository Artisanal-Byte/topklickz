---
const { hero } = Astro.props;
import { Icon } from "astro-icon/components";
import { Image } from "astro:assets";
---

<section class="relative overflow-hidden">
    <div class="mx-auto max-w-7xl px-6 lg:px-8 lg:py-20 py-10">
        <div class="grid items-center gap-0 lg:grid-row-3">
            <!-- LEFT -->
            <div class="lg:col-row-2 mt-3">
                <h1
                    class="font-clash text-4xl font-bold leading-[93%] tracking-normal text-black lg:text-[70px]"
                >
                    {hero?.title}
                </h1>

                <h2
                    class="mt-3 font-clash text-4xl font-semibold leading-[93%] tracking-normal
        bg-gradient-to-r
        from-orange-500
        via-pink-500
        to-violet-600
        bg-clip-text
        text-transparent
        lg:text-[70px]"
                >
                    {hero?.subtitle}
                </h2>

                <h3
                    class="mt-3 font-clash text-4xl font-bold leading-[93%] tracking-normal text-black lg:text-[68px]"
                >
                    {hero?.description}
                </h3>

                <a
                    href={hero?.buttonLink}
                    class="group mt-5 lg:mt-16 inline-flex items-center gap-4 font-geist text-[28px] font-normal leading-[114%] tracking-normal"
                >
                    {hero?.buttonText}

                    <Icon
                        name={hero.buttonIcon}
                        class="h-8 w-8 transition-transform duration-300 group-hover:translate-x-1"
                    />
                </a>
            </div>
            <!-- RIGHT -->
            <div class="flex items-start justify-end lg:-mt-10 mt-5">
                {
                    hero?.image && (
                        <Image
                            src={hero.image}
                            alt={hero?.title}
                            width={380}
                            height={420}
                        />
                    )
                }
            </div>
        </div>
    </div>
</section>
