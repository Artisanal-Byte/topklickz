---
import { Icon } from "astro-icon/components";
import { Image } from "astro:assets";

const { services } = Astro.props;
---

<section
  class="relative overflow-visible bg-white"
  data-services-section
>
  <!-- Section Heading -->
  <div
    class="mx-auto max-w-7xl px-4 pb-14 pt-16 sm:px-6 md:pb-20 md:pt-24 lg:px-8"
  >
    <h2
      class="font-clash text-3xl font-semibold leading-[90%] text-black uppercase sm:text-4xl lg:text-[50px]"
    >
      {services.title}
    </h2>

    <h2
      class="mt-4 font-clash text-3xl font-semibold leading-[90%] uppercase sm:text-4xl lg:text-[50px]"
    >
      <span
        class="gradient-text"
      >
        {services.gradientTitle}
      </span>

      <span class="text-black">
        {services.endTitle}
      </span>
    </h2>
  </div>

  <!-- Services -->
  <div
    class="relative w-full overflow-visible"
    data-services-stack
  >
    {
      services.items.map((service, serviceIndex) => (
        <article
          class="
            sticky top-0 isolate w-full border-t border-gray-200 bg-white py-6 sm:py-7 lg:py-8
          "
          style={`z-index: ${serviceIndex + 10};`}
          data-service-panel
        >
          <div
            class="
              mx-auto grid w-full max-w-7xl content-center gap-10 px-5 pt-12 transition-[transform,opacity] duration-300 ease-out
              will-change-transform
              sm:px-6
              lg:grid-cols-2
              lg:gap-16
              lg:px-8
              lg:pt-16
            "
            data-service-content
          >
            <!-- Left Content -->
            <div>
              <div
                class="
                  flex items-start
                  gap-4
                  sm:gap-7
                  lg:gap-8
                "
              >
                <!-- Service Number -->
                <span
                  class="
                    w-9 shrink-0
                    font-clash text-2xl
                    font-light text-gray-400

                    sm:w-12 sm:text-3xl
                    lg:text-4xl
                  "
                >
                  {service.number}
                </span>

                <div class="min-w-0 flex-1">
                  <!-- Service Title -->
                  <h3
                    class="
                      font-clash
                      text-3xl font-bold
                      leading-[93%] text-black

                      sm:text-[40px]
                      lg:text-[48px]
                    "
                  >
                    {service.title}
                  </h3>

                  <!-- Features -->
                  <ul
                    class="
                      mt-7 space-y-3
                      sm:mt-8
                    "
                    aria-label={`${service.title} features`}
                    data-features-list
                  >
                    {
                      service.features?.map(
                        (feature, featureIndex) => (
                          <li
                            class="
                              group flex cursor-pointer
                              items-center gap-3

                              font-clash
                              text-lg font-normal
                              leading-[106%]
                              text-gray-400

                              outline-none

                              transition-all
                              duration-300 ease-out

                              hover:translate-x-0.5
                              hover:text-black

                              focus-visible:translate-x-0.5
                              focus-visible:text-black
                              focus-visible:outline-none

                              data-[active=true]:translate-x-0.5
                              data-[active=true]:text-black

                              sm:text-[22px]
                              lg:text-[32px]
                            "
                            data-feature-item
                            data-active={
                              featureIndex === 0
                                ? "true"
                                : "false"
                            }
                            tabindex="0"
                          >
                            <!-- Gradient Indicator -->
                            <span
                              class="
                                block h-[5px] w-0
                                shrink-0 rounded-full

                                bg-gradient-to-r
                                from-orange-500
                                via-pink-500
                                to-violet-600

                                opacity-0

                                transition-all
                                duration-300 ease-out

                                group-hover:w-[18px]
                                group-hover:opacity-100

                                group-focus-visible:w-[18px]
                                group-focus-visible:opacity-100

                                group-data-[active=true]:w-[18px]
                                group-data-[active=true]:opacity-100
                              "
                              aria-hidden="true"
                            ></span>

                            <span>{feature}</span>
                          </li>
                        ),
                      )
                    }
                  </ul>

                  <!-- Button -->
                <a
                    href={service.buttonLink}
                    class="group mt-10 inline-flex max-w-full rounded-full bg-[radial-gradient(circle_at_center,#FEC053_0%,#F2203E_33%,#B729A8_65%,#5342D6_100%)] p-[1.5px] transition-all duration-300 sm:mt-14"
                  >
                    <span
                      class="flex w-full items-center gap-2 rounded-full bg-white px-2 py-2 pr-4 transition-colors duration-300 group-hover:bg-violet-50 sm:w-auto sm:gap-4 sm:px-2 sm:pr-6"
                    >
                      <!-- Icon -->
                      <span
                        class="flex h-9 w-9 shrink-0 items-center justify-center rounded-full gradient-bg transition-transform duration-300 group-hover:rotate-45 sm:h-10 sm:w-10"
                      >
                        <Icon
                          name={service.buttonIcon}
                          class="h-4 w-4 text-white sm:h-5 sm:w-5"
                        />
                      </span>

                      <!-- Text -->
                      <span
                        class="whitespace-nowrap font-clash text-sm font-medium leading-[100%] tracking-[0] text-black sm:text-[20px]"
                      >
                        {service.buttonText}
                      </span>
                    </span>
                  </a>
                </div>
              </div>
            </div>

            <!-- Right Content -->
            <div class="lg:pt-1">
              <!-- Description -->
              <p
                class="
                  max-w-xl
                  font-clash
                  text-sm leading-relaxed
                  text-gray-800

                  sm:text-base

                  lg:text-2xl
                  lg:leading-relaxed
                "
              >
                {service.description}
              </p>

              <!-- Image -->
              {
                service.image && (
                  <div
                    class="
                      group mt-6 overflow-hidden
                      rounded-xl
                      bg-gray-100

                      sm:mt-10
                      md:mt-12
                    "
                  >
                    <Image
                      src={service.image}
                      alt={service.title}
                      width={800}
                      height={500}
                      loading={
                        serviceIndex === 0
                          ? "eager"
                          : "lazy"
                      }
                      decoding="async"
                      class="
                        h-auto w-full max-h-[220px]
                        object-cover

                        transition-transform
                        duration-700 ease-out

                        sm:max-h-none
                        group-hover:scale-[1.025]
                      "
                    />
                  </div>
                )
              }
            </div>
          </div>
        </article>
      ))
    }
  </div>
</section>

<script is:inline>
  // @ts-nocheck

  (() => {
    let serviceGroups = [];
    let animationFrameId = 0;

    const clamp = (value, minimum, maximum) => {
      return Math.min(
        Math.max(value, minimum),
        maximum,
      );
    };

    const collectServicePanels = () => {
      const sections = document.querySelectorAll(
        "[data-services-section]",
      );

      serviceGroups = Array.from(sections).map(
        (section) => {
          const panels = Array.from(
            section.querySelectorAll(
              "[data-service-panel]",
            ),
          )
            .map((panel) => {
              const content = panel.querySelector(
                "[data-service-content]",
              );

              if (!content) {
                return null;
              }

              return {
                panel,
                content,
              };
            })
            .filter(Boolean);

          return {
            section,
            panels,
          };
        },
      );
    };

    const initializeFeatureLists = () => {
      const featureLists =
        document.querySelectorAll(
          "[data-features-list]",
        );

      featureLists.forEach((list) => {
        if (
          list.dataset.initialized === "true"
        ) {
          return;
        }

        list.dataset.initialized = "true";

        const items = Array.from(
          list.querySelectorAll(
            "[data-feature-item]",
          ),
        );

        if (!items.length) {
          return;
        }

        const setActiveItem = (selectedItem) => {
          items.forEach((item) => {
            item.dataset.active =
              item === selectedItem
                ? "true"
                : "false";
          });
        };

        const getFeatureItem = (event) => {
          if (
            !(event.target instanceof Element)
          ) {
            return null;
          }

          const item = event.target.closest(
            "[data-feature-item]",
          );

          if (
            !item ||
            !list.contains(item)
          ) {
            return null;
          }

          return item;
        };

        list.addEventListener(
          "pointerover",
          (event) => {
            if (
              !window.matchMedia(
                "(hover: hover)",
              ).matches
            ) {
              return;
            }

            const item = getFeatureItem(event);

            if (item) {
              setActiveItem(item);
            }
          },
        );

        list.addEventListener(
          "click",
          (event) => {
            const item = getFeatureItem(event);

            if (item) {
              setActiveItem(item);
            }
          },
        );

        list.addEventListener(
          "focusin",
          (event) => {
            const item = getFeatureItem(event);

            if (item) {
              setActiveItem(item);
            }
          },
        );

        list.addEventListener(
          "pointerleave",
          () => {
            if (
              window.matchMedia(
                "(hover: hover)",
              ).matches
            ) {
              setActiveItem(items[0]);
            }
          },
        );

        list.addEventListener(
          "focusout",
          (event) => {
            const nextElement =
              event.relatedTarget;

            if (
              !(nextElement instanceof Node) ||
              !list.contains(nextElement)
            ) {
              setActiveItem(items[0]);
            }
          },
        );
      });
    };

    const resetServicePanels = () => {
      serviceGroups.forEach((group) => {
        group.panels.forEach((entry) => {
          entry.content.style.transform =
            "translate3d(0, 0, 0) scale(1)";

          entry.content.style.opacity = "1";
        });
      });
    };

    const updateServicePanels = () => {
      const reducedMotion =
        window.matchMedia(
          "(prefers-reduced-motion: reduce)",
        ).matches;

      if (reducedMotion) {
        resetServicePanels();
        return;
      }

      const viewportHeight =
        window.innerHeight ||
        document.documentElement.clientHeight;

      serviceGroups.forEach((group) => {
        group.panels.forEach(
          (entry, index) => {
            const nextEntry =
              group.panels[index + 1];

            if (!nextEntry) {
              entry.content.style.transform =
                "translate3d(0, 0, 0) scale(1)";

              entry.content.style.opacity = "1";
              return;
            }

            const nextPanelTop =
              nextEntry.panel
                .getBoundingClientRect()
                .top;

            const animationRange =
              viewportHeight * 0.68;

            const progress = clamp(
              (viewportHeight - nextPanelTop) /
                animationRange,
              0,
              1,
            );

            const translateY = progress * -18;
            const scale = 1 - progress * 0.012;
            const opacity = 1 - progress * 0.22;

            entry.content.style.transform = `
              translate3d(
                0,
                ${translateY.toFixed(2)}px,
                0
              )
              scale(${scale.toFixed(4)})
            `;

            entry.content.style.opacity =
              opacity.toFixed(3);
          },
        );
      });
    };

    const requestServiceUpdate = () => {
      if (animationFrameId) {
        return;
      }

      animationFrameId =
        window.requestAnimationFrame(() => {
          updateServicePanels();
          animationFrameId = 0;
        });
    };

    const initializeServices = () => {
      collectServicePanels();
      initializeFeatureLists();
      requestServiceUpdate();
    };

    initializeServices();

    if (
      document.documentElement.dataset
        .servicesEventsBound !== "true"
    ) {
      document.documentElement.dataset
        .servicesEventsBound = "true";

      window.addEventListener(
        "scroll",
        requestServiceUpdate,
        {
          passive: true,
        },
      );

      window.addEventListener(
        "resize",
        () => {
          collectServicePanels();
          requestServiceUpdate();
        },
        {
          passive: true,
        },
      );

      document.addEventListener(
        "astro:page-load",
        initializeServices,
      );
    }
  })();
</script>
